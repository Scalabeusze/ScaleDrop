# Local development defaults. Copy this file as `.env` in local directory.
# Replace passwords with sensible values, for example: $(head -c 24 /dev/urandom | base64)
DB_URL=host:port/database_name
DB_USERNAME=postgres
DB_PASSWORD=replace-me
SECURITY_JWT_SECRET=replace-with-at-least-32-random-bytes
SECURITY_ACCESS_DOCUMENTATION_PASSWORD=replace-me
SECURITY_ACCESS_INTERNAL_PASSWORD=replace-me
GOOGLE_CLIENT_ID=000000000000-00000000000000000000000000000000.apps.googleusercontent.com
GOOGLE_SECRET=000000-00000000000000000-0000000000
